@page
@model WebApp_Security.Pages.WeatherForecastModel
@{
    ViewData["Title"] = "天气预报";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h3 class="card-title mb-0">@ViewData["Title"]</h3>
                        <div>
                            <a asp-page="/WeatherForecast" class="btn btn-outline-primary btn-sm">刷新</a>
                            <a asp-page="/Index" class="btn btn-link btn-sm">返回</a>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger">@Model.ErrorMessage</div>
                    }
                    else if (Model.WeatherForecastItems == null || !Model.WeatherForecastItems.Any())
                    {
                        <div class="alert alert-info">暂无天气数据或请求失败。</div>
                    }
                    else
                    {
                        <div class="mb-2 text-muted">共 @Model.WeatherForecastItems.Count 条记录</div>

                        <div class="table-responsive">
                            <table class="table table-striped table-bordered align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>日期</th>
                                        <th class="text-end">温度 (°C)</th>
                                        <th class="text-end">温度 (°F)</th>
                                        <th>描述</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.WeatherForecastItems)
                                    {
                                        <tr>
                                            <td>@item.Date.ToString("yyyy-MM-dd")</td>
                                            <td class="text-end">@item.TemperatureC</td>
                                            <td class="text-end">@item.TemperatureF</td>
                                            <td>@item.Summary</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
