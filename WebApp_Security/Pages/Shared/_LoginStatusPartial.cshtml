@if (User?.Identity?.IsAuthenticated == true)
{
    var displayName = User.Identity?.Name ?? User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "用户";
    <li class="nav-item dropdown">
        <a class="nav-link dropdown-toggle text-white" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <span class="me-1">@displayName</span>
        </a>
        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
            <li class="px-3 py-2">
                <div class="small text-muted">@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</div>
            </li>
            <li><a class="dropdown-item" asp-page="/Settings">个人设置</a></li>
            <li><hr class="dropdown-divider" /></li>
            <li>
                <form asp-page="/Account/Logout" method="post" class="px-3 py-1">
                    <button type="submit" class="btn btn-outline-danger w-100">登出</button>
                </form>
            </li>
        </ul>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-white" asp-area="" asp-page="/Account/Login">登录</a>
    </li>
}
