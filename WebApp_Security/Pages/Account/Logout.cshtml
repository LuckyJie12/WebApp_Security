@page
@model WebApp_Security.Pages.Account.LogoutModel
@{
    ViewData["Title"] = "登出";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <h3 class="card-title mb-3">@ViewData["Title"]</h3>
                    <p class="lead">正在登出……</p>
                    <p class="small text-muted">如果没有自动返回，请 <a asp-page="/Index">点击这里</a>。</p>
                </div>
            </div>
        </div>
    </div>
</div>
