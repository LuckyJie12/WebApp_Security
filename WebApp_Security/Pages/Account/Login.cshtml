@page
@model WebApp_Security.Pages.Account.LoginModel
@{
    ViewData["Title"] = "登录";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h3 class="card-title mb-3">@ViewData["Title"]</h3>

                    <form method="post" novalidate>
                        <input type="hidden" asp-for="ReturnUrl" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                        <div class="mb-3">
                            <label asp-for="Credential.Username" class="form-label">用户名</label>
                            <input asp-for="Credential.Username" class="form-control" />
                            <span asp-validation-for="Credential.Username" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Credential.Password" class="form-label">密码</label>
                            <input asp-for="Credential.Password" type="password" class="form-control" />
                            <span asp-validation-for="Credential.Password" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <div class="form-check">
                                <input asp-for="Credential.RememberMe" class="form-check-input" />
                                <label asp-for="Credential.RememberMe" class="form-check-label">记住我</label>
                            </div>

                            <button type="submit" class="btn btn-primary">登录</button>
                            <a asp-page="/Index" class="btn btn-link">返回</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
